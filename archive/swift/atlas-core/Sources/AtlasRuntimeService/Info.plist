<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle identity — TCC keys permissions to this ID, not the binary hash -->
    <key>CFBundleIdentifier</key>
    <string>com.rxalabs.atlas.runtime</string>
    <key>CFBundleName</key>
    <string>AtlasRuntimeService</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>0.2.0</string>
    <key>CFBundleExecutable</key>
    <string>AtlasRuntimeService</string>

    <!-- Suppress Dock icon / App Switcher entry for this background daemon -->
    <key>LSUIElement</key>
    <true/>
    <key>LSBackgroundOnly</key>
    <true/>

    <!-- ─── Privacy usage descriptions (TCC) ──────────────────────────────
         All AppleScript automation (Calendar, Reminders, Contacts, Mail,
         Safari, Notes, Music, Spotify) is gated by NSAppleEventsUsageDescription.
         macOS shows this string in the per-app Automation prompt.             -->
    <key>NSAppleEventsUsageDescription</key>
    <string>Atlas sends Apple Events to automate Calendar, Reminders, Contacts, Mail, Safari, Notes, and Music on your behalf.</string>

    <!-- Direct framework access — included here so future skills that use
         EventKit / Contacts.framework / EventKitReminders work without a
         separate Info.plist update.                                          -->
    <key>NSCalendarsUsageDescription</key>
    <string>Atlas reads and creates calendar events when you ask it to manage your schedule.</string>
    <key>NSRemindersUsageDescription</key>
    <string>Atlas reads and creates reminders when you ask it to manage your tasks.</string>
    <key>NSContactsUsageDescription</key>
    <string>Atlas searches your contacts to look up names, phone numbers, and email addresses.</string>

    <!-- File access — FileSystemSkill uses security-scoped bookmarks, but
         this description covers any direct file-open panel usage.           -->
    <key>NSOpenPanelUsageDescription</key>
    <string>Atlas needs access to this file or folder to complete your request.</string>
</dict>
</plist>
