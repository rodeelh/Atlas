<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        AtlasRuntimeService is intentionally NOT sandboxed — it needs to:
          • Spawn osascript subprocesses (AppleScript automation)
          • Make outbound network connections (OpenAI, weather, Telegram)
          • Read/write files outside the container (FileSystemSkill)
          • Launch and control other applications (SystemActionSkill)

        com.apple.security.automation.apple-events allows this process to
        send Apple Events to other applications. macOS still requires the
        user to grant per-app Automation access the first time each target
        app (Music, Calendar, etc.) is controlled.
    -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
	<key>keychain-access-groups</key>
	<array>
		<string>__ATLAS_APP_IDENTIFIER_PREFIX__com.projectatlas.shared</string>
	</array>
</dict>
</plist>
