<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.projectatlas.runtime</string>
    <key>ProgramArguments</key>
    <array>
        <string>EXECUTABLE_PATH_PLACEHOLDER</string>
    </array>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>LOGS_PATH_PLACEHOLDER/atlas-runtime.log</string>
    <key>StandardErrorPath</key>
    <string>LOGS_PATH_PLACEHOLDER/atlas-runtime-error.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>HOME_PATH_PLACEHOLDER</string>
    </dict>
</dict>
</plist>
