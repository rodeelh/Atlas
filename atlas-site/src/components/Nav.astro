---
import Wordmark from './Wordmark.astro';

const links = [
  { href: '#features', label: 'features' },
  { href: '#how', label: 'architecture' },
  { href: '#privacy', label: 'privacy' },
  { href: 'https://github.com/rodeelh/Atlas', label: 'github', external: true },
];
---
<header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center focus-ring rounded" aria-label="atlas home">
      <Wordmark size={22} />
    </a>

    <ul class="hidden items-center gap-8 font-mono text-sm text-text-2 md:flex">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="nav-link focus-ring rounded px-1 py-0.5 hover:text-text transition-colors"
            data-nav-link={l.href.startsWith('#') ? l.href.slice(1) : undefined}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noreferrer' : undefined}
          >{l.label}</a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/rodeelh/Atlas/releases/latest"
        class="focus-ring rounded border border-accent/40 bg-accent/10 px-3.5 py-1.5 font-mono text-sm text-accent hover:bg-accent/20 hover:shadow-glow-soft transition"
        target="_blank" rel="noreferrer"
      >download</a>

      <button
        type="button"
        class="nav-toggle focus-ring rounded border border-border p-2 text-text-2 md:hidden"
        aria-controls="mobile-nav"
        aria-expanded="false"
        aria-label="toggle menu"
      >
        <svg class="nav-icon-open" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <line x1="2" y1="5"  x2="16" y2="5"  />
          <line x1="2" y1="9"  x2="16" y2="9"  />
          <line x1="2" y1="13" x2="16" y2="13" />
        </svg>
        <svg class="nav-icon-close hidden" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <line x1="3" y1="3" x2="15" y2="15" />
          <line x1="15" y1="3" x2="3" y2="15" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-nav" class="hidden border-t border-border bg-bg/95 backdrop-blur md:hidden">
    <ul class="mx-auto flex max-w-6xl flex-col gap-1 px-6 py-3 font-mono text-sm">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="nav-link block rounded px-2 py-2 text-text-2 hover:bg-surface hover:text-text focus-ring"
            data-nav-link={l.href.startsWith('#') ? l.href.slice(1) : undefined}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noreferrer' : undefined}
          >{l.label}</a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const panel  = document.getElementById('mobile-nav');
  const iconOpen  = toggle?.querySelector('.nav-icon-open');
  const iconClose = toggle?.querySelector('.nav-icon-close');

  if (toggle && panel) {
    const setOpen = (open: boolean) => {
      panel.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      iconOpen?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
    };
    toggle.addEventListener('click', () => setOpen(panel.classList.contains('hidden')));
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  }

  // Active section highlighting
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]'));
  const sectionIds = Array.from(new Set(navLinks.map((l) => l.dataset.navLink!).filter(Boolean)));
  const sections = sectionIds
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => !!el);

  if (sections.length) {
    const setActive = (id: string | null) => {
      navLinks.forEach((l) => l.classList.toggle('is-active', l.dataset.navLink === id));
    };
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible) setActive(visible.target.id);
      },
      { rootMargin: '-40% 0px -50% 0px', threshold: [0, 0.25, 0.5] },
    );
    sections.forEach((s) => io.observe(s));
  }
</script>

<style>
  .nav-link.is-active { color: #E0E0FF; }
  .nav-link.is-active::after {
    content: '';
    display: block;
    height: 1px;
    margin-top: 2px;
    background: #00FF99;
    box-shadow: 0 0 6px rgba(0,255,153,0.6);
  }
  #mobile-nav .nav-link.is-active::after { display: none; }
  #mobile-nav .nav-link.is-active {
    background: rgba(0,255,153,0.08);
    color: #E0E0FF;
  }
</style>
