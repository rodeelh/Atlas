---
const features = [
  {
    cmd: 'providers',
    title: 'pick your brain',
    body: 'openai, anthropic, gemini, or a local model through lm studio. switch any time without losing the thread.',
  },
  {
    cmd: 'skills',
    title: 'give it hands',
    body: 'browse the web, read files, run a command, send a message, check the weather. you decide what it can touch.',
  },
  {
    cmd: 'memory',
    title: 'it remembers',
    body: 'names, places, what mattered last week. it tells you what it kept, and forgets when you ask.',
  },
  {
    cmd: 'dashboards',
    title: 'show it back',
    body: 'ask for a view of your day, your inbox, your spending — and it builds a small dashboard you can keep.',
  },
  {
    cmd: 'teams',
    title: 'split the work',
    body: 'give it a small crew of focused helpers. one researches, one writes, one keeps notes. you stay in the chair.',
  },
  {
    cmd: 'comms',
    title: 'meet you where you are',
    body: 'talk to it from telegram or discord. same companion, same memory, same conversation.',
  },
];
---
<section id="features">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="mb-16 flex items-baseline gap-4" data-reveal>
      <span class="font-mono text-sm text-accent">// 01</span>
      <h2 class="font-mono text-2xl text-text md:text-3xl"><span data-typed-heading>features</span></h2>
    </div>

    <div class="grid gap-px overflow-hidden rounded border border-border bg-border md:grid-cols-2 lg:grid-cols-3">
      {features.map((f, i) => (
        <article
          class="feat-card group relative overflow-hidden bg-surface p-7 transition hover:bg-surface-2 hover:shadow-glow-soft"
          data-reveal
          style={`--reveal-delay: ${i * 70}ms;`}
        >
          <div class="mb-4 font-mono text-xs text-accent">{f.cmd}</div>
          <h3 class="mb-3 font-mono text-lg text-text">{f.title}</h3>
          <p class="text-sm leading-relaxed text-text-2">{f.body}</p>
          <div class="mt-5 h-5 overflow-hidden font-mono text-[11px] text-text-3">
            <span class="block translate-y-5 opacity-0 transition duration-300 group-hover:translate-y-0 group-hover:opacity-100 group-hover:text-accent">
              → ready when you are
            </span>
          </div>
          <span class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent opacity-0 transition group-hover:opacity-100"></span>
        </article>
      ))}
    </div>
  </div>
</section>
