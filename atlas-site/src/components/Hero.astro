---
import Wordmark from './Wordmark.astro';
import Terminal from './Terminal.astro';
---
<section class="hero-station relative overflow-hidden">
  <div class="hero-station-base pointer-events-none absolute inset-0" aria-hidden="true"></div>
  <div class="hero-station-dots pointer-events-none absolute inset-0" aria-hidden="true"></div>
  <div class="hero-station-vignette pointer-events-none absolute inset-0" aria-hidden="true"></div>

  <div class="relative mx-auto grid max-w-6xl gap-16 px-6 pb-28 pt-24 md:pb-40 md:pt-32 lg:grid-cols-[1.1fr_1fr] lg:items-center lg:gap-12">
    <div>
      <div class="mb-8 flex items-center gap-3 font-mono text-xs text-text-2" data-status-pill>
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent shadow-glow-soft animate-pulse"></span>
        <span data-status-text>ready when you are</span>
      </div>

      <Wordmark size={72} animated class="mb-10" />

      <h1 class="max-w-3xl font-mono text-3xl leading-tight text-text md:text-5xl md:leading-[1.1]">
        A companion,
        <br />
        <span class="text-text-2">not a tool.</span>
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-text-2">
        Atlas is a companion who remembers you, grows with you, and is there
        when you need to think, write, plan, or just talk things through. Yours alone.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="https://github.com/rodeelh/Atlas/releases/latest"
          class="group inline-flex items-center gap-2 rounded bg-accent px-5 py-3 font-mono text-sm font-medium text-bg shadow-glow hover:shadow-[0_0_32px_rgba(0,255,153,0.35)] transition"
          target="_blank" rel="noreferrer"
        >
          <span aria-hidden="true">▸</span>
          get atlas
        </a>
        <a
          href="#features"
          class="inline-flex items-center gap-2 rounded border border-border-2 px-5 py-3 font-mono text-sm text-text hover:border-accent/40 hover:text-accent transition"
        >see what it does →</a>
      </div>
    </div>

    <div class="lg:pl-4">
      <Terminal />
    </div>
  </div>
</section>

<style>
  /* Hero background — adapted from Team HQ Atlas Station card */
  .hero-station-base {
    background:
      radial-gradient(ellipse at 92% 8%,  rgba(0, 255, 153, 0.22) 0%, transparent 52%),
      radial-gradient(ellipse at 8%  92%, rgba(0, 255, 153, 0.10) 0%, transparent 46%),
      linear-gradient(160deg, rgba(10, 10, 26, 0.85), #060612 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 75% at 50% 50%, black 0%, rgba(0,0,0,0.7) 55%, transparent 100%);
            mask-image: radial-gradient(ellipse 70% 75% at 50% 50%, black 0%, rgba(0,0,0,0.7) 55%, transparent 100%);
  }
  .hero-station-dots {
    background-image: radial-gradient(circle, rgba(0, 255, 153, 0.45) 1px, transparent 1px);
    background-size: 26px 26px;
    -webkit-mask-image: radial-gradient(ellipse 48% 55% at 50% 50%, black 0%, transparent 100%);
            mask-image: radial-gradient(ellipse 48% 55% at 50% 50%, black 0%, transparent 100%);
    -webkit-mask-size: 200% 200%;
            mask-size: 200% 200%;
    animation: hero-dot-drift 10s ease-in-out infinite;
    opacity: 0.9;
  }
  @keyframes hero-dot-drift {
    0%   { -webkit-mask-position: 20% 20%; mask-position: 20% 20%; }
    25%  { -webkit-mask-position: 75% 10%; mask-position: 75% 10%; }
    50%  { -webkit-mask-position: 80% 75%; mask-position: 80% 75%; }
    75%  { -webkit-mask-position: 20% 80%; mask-position: 20% 80%; }
    100% { -webkit-mask-position: 20% 20%; mask-position: 20% 20%; }
  }
  /* Static vignette — fades the dot grid + base into the page bg at the edges.
     Stacked so the bottom edge fully resolves to page bg before the next section. */
  .hero-station-vignette {
    background:
      linear-gradient(to bottom, transparent 0%, transparent 55%, rgba(6,6,18,0.85) 88%, #060612 100%),
      linear-gradient(to top,    transparent 0%, transparent 70%, rgba(6,6,18,0.55) 92%, #060612 100%),
      radial-gradient(
        ellipse 70% 75% at 50% 45%,
        transparent 0%,
        transparent 35%,
        rgba(6,6,18,0.55) 75%,
        #060612 100%
      );
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-station-dots { animation: none; }
  }
</style>

<script>
  const statusEl = document.querySelector('[data-status-text]') as HTMLElement | null;
  if (statusEl) {
    const lines = [
      'ready when you are',
      'remembers what matters',
      'learns new skills on its own',
      'stays on your machine',
    ];
    let i = 0;
    statusEl.style.transition = 'opacity 220ms ease';
    setInterval(() => {
      statusEl.style.opacity = '0';
      setTimeout(() => {
        i = (i + 1) % lines.length;
        statusEl.textContent = lines[i];
        statusEl.style.opacity = '1';
      }, 220);
    }, 3800);
  }
</script>
