---
import Wordmark from './Wordmark.astro';
---
<footer class="border-t border-border">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6 py-12 md:flex-row md:items-center md:justify-between">
    <div class="flex flex-col gap-3">
      <Wordmark size={20} />
      <p class="font-mono text-xs text-text-3">© 2026 RXA Labs · MIT licensed</p>
    </div>
    <ul class="flex flex-wrap gap-6 font-mono text-sm text-text-2">
      <li><a href="https://github.com/rodeelh/Atlas" class="hover:text-accent transition" target="_blank" rel="noreferrer">github</a></li>
      <li><a href="https://github.com/rodeelh/Atlas/releases" class="hover:text-accent transition" target="_blank" rel="noreferrer">releases</a></li>
      <li><a href="https://github.com/rodeelh/Atlas/issues" class="hover:text-accent transition" target="_blank" rel="noreferrer">issues</a></li>
    </ul>
  </div>
</footer>
