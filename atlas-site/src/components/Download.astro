---
---
<section id="download" class="border-b border-border">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="mb-16 flex items-baseline gap-4" data-reveal>
      <span class="font-mono text-sm text-accent">// 05</span>
      <h2 class="font-mono text-2xl text-text md:text-3xl"><span data-typed-heading>install</span></h2>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:gap-12">
      <div class="rounded border border-accent/30 bg-surface p-8 shadow-glow-soft transition hover:shadow-[0_0_40px_rgba(0,255,153,0.18)]" data-reveal>
        <div class="mb-4 font-mono text-xs text-accent">// recommended</div>
        <h3 class="mb-2 font-mono text-xl text-text">Download for macOS</h3>
        <p class="mb-6 text-sm leading-relaxed text-text-2">
          Signed and notarized. Installs as a launchd agent on port 1984. Works on macOS 14 (Sonoma) and later — Apple Silicon &amp; Intel.
        </p>
        <a
          href="https://github.com/rodeelh/Atlas/releases/latest"
          class="inline-flex items-center gap-2 rounded bg-accent px-5 py-3 font-mono text-sm font-medium text-bg shadow-glow hover:shadow-[0_0_32px_rgba(0,255,153,0.35)] transition"
          target="_blank" rel="noreferrer"
        >▸ get the latest release</a>
        <p class="mt-4 font-mono text-xs text-text-3">→ github.com/rodeelh/Atlas/releases</p>
      </div>

      <div class="rounded border border-border bg-surface p-8 transition hover:border-accent/30" data-reveal style="--reveal-delay: 120ms;">
        <div class="mb-4 font-mono text-xs text-text-2">// from source</div>
        <h3 class="mb-2 font-mono text-xl text-text">One-line install</h3>
        <p class="mb-6 text-sm leading-relaxed text-text-2">
          Clone, build, and install the launchd daemon in one shot. Requires Go 1.22+ and Node 20+.
        </p>
        <button
          type="button"
          class="group relative block w-full cursor-copy rounded border border-border bg-bg p-4 pr-14 text-left font-mono text-xs leading-relaxed hover:border-accent/40 transition"
          data-copy="git clone https://github.com/rodeelh/Atlas.git && cd Atlas && make install"
          aria-label="Copy one-line install command"
        >
          <span class="absolute right-3 top-1/2 -translate-y-1/2 font-mono text-[10px] text-text-3 transition group-hover:text-accent" data-copy-label>copy ⎘</span>
          <div class="overflow-x-auto whitespace-nowrap">
            <span class="text-accent">$</span>
            <span class="text-text">git clone https://github.com/rodeelh/Atlas.git</span>
            <span class="text-text-3"> &amp;&amp; </span>
            <span class="text-text">cd Atlas</span>
            <span class="text-text-3"> &amp;&amp; </span>
            <span class="text-accent">make install</span>
          </div>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy') ?? '';
      const label = btn.querySelector('[data-copy-label]') as HTMLElement | null;
      try {
        await navigator.clipboard.writeText(text);
        if (label) {
          const original = label.textContent;
          label.textContent = 'copied ✓';
          label.style.color = '#00FF99';
          setTimeout(() => {
            label.textContent = original;
            label.style.color = '';
          }, 1400);
        }
      } catch {
        if (label) label.textContent = 'copy failed';
      }
    });
  });
</script>
