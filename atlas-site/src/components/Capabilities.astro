---
const rows = [
  ['approvals',   'Per-action approval policies. Auto-approve reads; gate writes, deletes, and sends.'],
  ['automations', 'GREMLINS.md — declarative recurring tasks the agent runs unattended.'],
  ['workflows',   'Multi-step JSON workflows with scoped tool prefixes and run history.'],
  ['vault',       'Separate Keychain item for agent-managed credentials, isolated from runtime keys.'],
  ['mind-thoughts', 'Persistent intents that survive across sessions. The agent picks them up between turns.'],
  ['api-validation', 'Pre-flight + live execution gate for new API integrations. Two-attempt audit log.'],
];
---
<section class="border-b border-border">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="mb-16 flex items-baseline gap-4" data-reveal>
      <span class="font-mono text-sm text-accent">// 03</span>
      <h2 class="font-mono text-2xl text-text md:text-3xl"><span data-typed-heading>capabilities</span></h2>
    </div>

    <ul class="divide-y divide-border rounded border border-border bg-surface">
      {rows.map(([k, v], i) => (
        <li
          class="group grid grid-cols-1 gap-2 px-6 py-5 transition hover:bg-surface-2 md:grid-cols-[200px_1fr] md:gap-8"
          data-reveal
          style={`--reveal-delay: ${i * 50}ms;`}
        >
          <span class="font-mono text-sm text-accent transition group-hover:translate-x-1">{k}</span>
          <span class="text-sm leading-relaxed text-text-2">{v}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
