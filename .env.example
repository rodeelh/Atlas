# Optional developer shell variables for repo scripts.
# Atlas itself does NOT auto-load this file and does NOT read provider secrets from it.
# Runtime credentials belong in Atlas Settings -> Credentials, which stores them in the macOS Keychain.

# Benchmark / smoke scripts
ATLAS_URL=http://127.0.0.1:1984
TEST_MSG=Ping from Project Atlas
RUNS=10
CONCURRENCY=2
LABEL=local-smoke

# Optional one-off script inputs
ANTHROPIC_API_KEY=
FORGE_EVAL_MODEL=
HF_TOKEN=
ATLAS_BROWSER_SMOKE=
